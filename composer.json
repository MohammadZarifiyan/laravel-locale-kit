{
    "name": "mohammad-zarifiyan/laravel-locale-kit",
    "description": "A Laravel package that provides structured locale metadata alongside traditional translation files.",
    "type": "library",
    "keywords": ["Laravel", "Locale"],
    "version": "1.0.1",
    "require": {
        "php": ">=8.1",
        "laravel/framework": ">=7"
    },
    "autoload": {
        "psr-4": {
            "MohammadZarifiyan\\LaravelLocaleKit\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Mohammad Zarifiyan",
            "email": "mohammadzarifiyan82@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "MohammadZarifiyan\\LaravelLocaleKit\\LocaleKitProvider"
            ]
        }
    }
}
